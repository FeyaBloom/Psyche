{
  "expo": {
    "name": "Psyche",
    "slug": "psyche",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "psyche",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.feyabloom.psyche"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1117"
      },
      "package": "com.feyabloom.psyche"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-asset",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
